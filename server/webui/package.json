{
	"name": "llampart",
	"private": true,
	"version": "1.4.1",
	"description": "Local chat Web UI designed for llama-server.",
	"license": "MIT",
	"author": "Marcin Gluziński",
	"type": "module",
	"scripts": {
		"dev": "bash scripts/dev.sh",
		"build": "vite build && ./scripts/post-build.sh",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"validate:settings": "node scripts/validate-settings-metadata.mjs",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"reset": "rm -rf .svelte-kit node_modules",
		"format": "prettier --write .",
		"lint": "prettier --check . && eslint .",
		"test": "npm run test:unit -- --run",
		"test:unit": "vitest --project=unit",
		"cleanup": "rm -rf .svelte-kit build node_modules",
		"dev:vite": "NODE_OPTIONS=\"--insecure-http-parser\" vite dev --host 0.0.0.0",
		"hooks:install": "bash scripts/install-git-hooks.sh"
	},
	"devDependencies": {
		"@eslint/compat": "^1.2.5",
		"@eslint/js": "^9.18.0",
		"@internationalized/date": "^3.10.1",
		"@lucide/svelte": "^0.515.0",
		"@sveltejs/adapter-static": "^3.0.10",
		"@sveltejs/kit": "^2.65.1",
		"@sveltejs/vite-plugin-svelte": "^7.1.2",
		"@tailwindcss/forms": "^0.5.9",
		"@tailwindcss/typography": "^0.5.15",
		"@tailwindcss/vite": "^4.3.1",
		"@types/mdast": "^4.0.4",
		"@types/node": "^24",
		"@vitest/coverage-v8": "^4.1.8",
		"bits-ui": "^2.14.4",
		"clsx": "^2.1.1",
		"dexie": "^4.0.11",
		"eslint": "^9.18.0",
		"eslint-config-prettier": "^10.0.1",
		"eslint-plugin-svelte": "^3.0.0",
		"globals": "^16.0.0",
		"mdsvex": "^0.12.3",
		"prettier": "^3.8.4",
		"prettier-plugin-svelte": "^4.1.0",
		"prettier-plugin-tailwindcss": "^0.8.0",
		"rehype-katex": "^7.0.1",
		"remark-math": "^6.0.0",
		"sass": "^1.93.3",
		"svelte": "^5.38.2",
		"svelte-check": "^4.0.0",
		"tailwind-merge": "^3.3.1",
		"tailwind-variants": "^3.2.2",
		"tailwindcss": "^4.3.1",
		"tw-animate-css": "^1.3.5",
		"typescript": "^5.0.0",
		"typescript-eslint": "^8.20.0",
		"unified": "^11.0.5",
		"uuid": "^14.0.0",
		"vite": "^8.0.16",
		"vitest": "^4.1.8"
	},
	"dependencies": {
		"@modelcontextprotocol/sdk": "^1.25.1",
		"highlight.js": "^11.11.1",
		"mode-watcher": "^1.1.0",
		"pdfjs-dist": "^5.4.54",
		"rehype-highlight": "^7.0.2",
		"rehype-stringify": "^10.0.1",
		"remark": "^15.0.1",
		"remark-breaks": "^4.0.0",
		"remark-gfm": "^4.0.1",
		"remark-html": "^16.0.1",
		"remark-rehype": "^11.1.2",
		"svelte-sonner": "^1.0.5",
		"unist-util-visit": "^5.0.0",
		"zod": "^4.2.1"
	},
	"overrides": {
		"cookie": "^0.7.2",
		"postcss": "^8.5.10",
		"uuid": "^14.0.0",
		"qs": "6.15.2",
		"ws": "8.20.1",
		"hono": "4.12.25"
	},
	"allowScripts": {
		"esbuild@0.27.7": true,
		"@parcel/watcher@2.5.6": true,
		"@tailwindcss/oxide@4.1.11": true
	}
}
